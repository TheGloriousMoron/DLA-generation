{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C Program (Windows - MSVC)",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/Fe${workspaceFolder}\\build\\dla_generation.exe",
                "/Fo${workspaceFolder}\\build\\",
                "${workspaceFolder}\\src\\*.c",
                "${workspaceFolder}\\include\\lodepng\\lodepng.c",
                "/I", "${workspaceFolder}\\include",
                "/I", "${workspaceFolder}\\include\\lodepng"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "detail": "Generated task to build using MSVC"
        },
        {
            "label": "Build C Program (Linux - GCC)",
            "type": "shell",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*.c",
                "${workspaceFolder}/include/lodepng/lodepng.c",
                "-I${workspaceFolder}/include/",
                "-o",
                "${workspaceFolder}/build/dla_generation"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Build using GCC (Linux)"
        }
    ]
}